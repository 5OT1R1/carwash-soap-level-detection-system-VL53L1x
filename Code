#include <Wire.h>
#include <VL53L1X.h>
#include <ESP8266WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>


VL53L1X sensor;

// ---- Unique device name ----
// Change this for each tank: "soap1", "soap2", ...
const char* device_name = "soap1"; //MUST BE UNIQUE FOR EACH SENSOR

// ---- Wi-Fi ----
const char* ssid1 = "ENTER USER WIFI SSID HERE";
const char* pass1 = "ENTER USER WIFI PASS HERE";
//const char* ssid2 = "ENTER OPTION SECONDARY SSID HERE"; //UNCOMMENT IF SECONDARY WIFI IS NEEDED
//const char* pass2 = "ENTER SECONDARY SSID PASS HERE";  //UNCOMMENT IF SECONDARY WIFI IS NEEDED

// ---- MQTT ----
const char* mqtt_server = "192.168.1.7";   // Replace with your HA Raspberry Pi IP
const int   mqtt_port   = 1883;
const char* mqtt_user   = "mqtt_user"; //OR YOUR MQTT USER ID
const char* mqtt_pass   = "MQTT PASSWORD";

// ---- Calibration ----
static const float IN_TO_MM = 25.4f;
static const float FULL_IN  = 1.33f;    // full at X INCHES
static const float EMPTY_IN = 28.5f;   // empty at X INCHES
static const float FULL_MM  = FULL_IN  * IN_TO_MM;  
static const float EMPTY_MM = EMPTY_IN * IN_TO_MM;  
static const float FULL_GAL = 30.0f;   // full tank gallons. CHANGE ACCORDING TO MAX CONTAINER GALLONS

WiFiClient espClient;
PubSubClient client(espClient);

// Topics
String t_dist_mm, t_dist_cm, t_dist_in, t_percent, t_gallons;
// (optional backward-compat topic)
String t_dist_legacy;

static float clampf(float v, float lo, float hi) {
  if (v < lo) return lo;
  if (v > hi) return hi;
  return v;
}

void connectWiFi() {
  Serial.println("Connecting to WiFi...");
  WiFi.begin(ssid1, pass1);
  unsigned long startAttempt = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) {
    delay(500); Serial.print(".");
  }
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("\nPrimary WiFi failed, trying backup...");
    WiFi.begin(ssid2, pass2);
    while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  }
  Serial.println("\nWiFi connected: " + WiFi.localIP().toString());
}

void reconnectMQTT() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    if (client.connect(device_name, mqtt_user, mqtt_pass)) {
      Serial.println("connected");
    } else {
      Serial.printf("failed, rc=%d retrying in 5s\n", client.state());
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  Wire.begin(D2, D1);  // SDA, SCL

  pinMode(D3, OUTPUT);
  digitalWrite(D3, HIGH); // Enable sensor via XSHUT

  // Build topics
  String base = String("soap_sensor/") + device_name + "/";
  t_dist_mm     = base + "distance_mm";
  t_dist_cm     = base + "distance_cm";
  t_dist_in     = base + "distance_in";
  t_percent     = base + "percent";
  t_gallons     = base + "gallons";
  t_dist_legacy = base + "distance";  // legacy mm topic (kept for compatibility)

  connectWiFi();
  client.setServer(mqtt_server, mqtt_port);
  // OTA setup
  ArduinoOTA.setHostname(device_name);   // so it shows up as "soap1" in IDE
  ArduinoOTA.setPassword(device_name); // optional but recommended - quote the password or no quote for variable

  ArduinoOTA.onStart([]() {
    Serial.println("OTA update starting...");
  });
  ArduinoOTA.onEnd([]() {
    Serial.println("\nOTA update complete.");
  });
  ArduinoOTA.onError([](ota_error_t error) {
    Serial.printf("OTA Error[%u]\n", error);
  });

  ArduinoOTA.begin();
  Serial.println("OTA ready, waiting for uploads...");

  sensor.setTimeout(500);
  if (!sensor.init()) {
    Serial.println("Failed to detect and initialize sensor!");
    while (1) { delay(1000); }
  }

  sensor.setDistanceMode(VL53L1X::Long);
  sensor.setMeasurementTimingBudget(50000); // 50 ms
  sensor.setROISize(4, 4);
  sensor.startContinuous(100);              // read every 100 ms
}

// Config
const int SAMPLES_PER_MIN = 60;   // how many samples to keep each minute
const float OUTLIER_PCT   = 0.10; // discard samples >10% away from mean

// Globals
float samples[SAMPLES_PER_MIN];
int sampleCount = 0;
unsigned long lastPublish = 0;

void loop() {
  if (WiFi.status() != WL_CONNECTED) connectWiFi();
  if (!client.connected()) reconnectMQTT();
  client.loop();        // keep MQTT alive
  ArduinoOTA.handle();  // keep OTA responsive


  int distance_mm = sensor.read();
  if (!sensor.timeoutOccurred() && distance_mm > 0) {
    // Store sample (convert to gallons right away or keep mm)
    samples[sampleCount++] = (float)distance_mm;

    if (sampleCount >= SAMPLES_PER_MIN) {
      // 1) Compute mean
      float sum = 0;
      for (int i = 0; i < sampleCount; i++) sum += samples[i];
      float mean = sum / sampleCount;

      // 2) Filter outliers
      float filteredSum = 0;
      int filteredCount = 0;
      for (int i = 0; i < sampleCount; i++) {
        if (fabs(samples[i] - mean) <= mean * OUTLIER_PCT) {
          filteredSum += samples[i];
          filteredCount++;
        }
      }

      // 3) Average survivors
      float filt_mm = (filteredCount > 0) ? (filteredSum / filteredCount) : mean;

      // 4) Convert to % and gallons
      float percent;
      if (filt_mm <= FULL_MM) percent = 100.0f;
      else if (filt_mm >= EMPTY_MM) percent = 0.0f;
      else percent = (EMPTY_MM - filt_mm) / (EMPTY_MM - FULL_MM) * 100.0f;

      float gallons = (percent / 100.0f) * FULL_GAL;
      float distance_cm = filt_mm / 10.0f;
      float distance_in = filt_mm / IN_TO_MM;

      // 5) Publish once per minute
      char buf[32];
      snprintf(buf, sizeof(buf), "%.0f", filt_mm);
      client.publish(t_dist_mm.c_str(), buf, true);
      client.publish(t_dist_legacy.c_str(), buf, true);

      snprintf(buf, sizeof(buf), "%.1f", distance_cm);
      client.publish(t_dist_cm.c_str(), buf, true);

      snprintf(buf, sizeof(buf), "%.2f", distance_in);
      client.publish(t_dist_in.c_str(), buf, true);

      snprintf(buf, sizeof(buf), "%.1f", percent);
      client.publish(t_percent.c_str(), buf, true);

      snprintf(buf, sizeof(buf), "%.2f", gallons);
      client.publish(t_gallons.c_str(), buf, true);

      Serial.printf("[PUB] %.0f mm | %.1f cm | %.2f in | %.1f%% | %.2f gal\n",
                    filt_mm, distance_cm, distance_in, percent, gallons);

      // reset for next minute
      sampleCount = 0;
    }
  }

  delay(1000); // 1 sample per second → 60 per minute
}
